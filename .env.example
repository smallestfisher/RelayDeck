# RelayDeck local environment template
# Copy this file to .env for local development and integration tests.

# HTTP server
HTTP_ADDR=:8080
APP_SECRET=change-this-local-secret
APP_UPSTREAM_SECRET_KEY=0123456789abcdef0123456789abcdef
GATEWAY_REQUEST_TIMEOUT=30s

# PostgreSQL main store. Use a test database for local integration tests.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/relaydeck_test?sslmode=disable

# Redis for admin sessions and later shared runtime state.
REDIS_URL=redis://localhost:6379/0

# Bootstrap owner. Used only when the users table is empty.
APP_BOOTSTRAP_OWNER_EMAIL=owner@example.com
APP_BOOTSTRAP_OWNER_PASSWORD=change-me
